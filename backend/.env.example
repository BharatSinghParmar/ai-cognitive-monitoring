# Environment Variables — Copy this file to .env and fill in your values
# NEVER commit the actual .env file!

# MongoDB connection string (use MongoDB Atlas for Railway deployment)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/exam_portal?retryWrites=true&w=majority

# Server port (Railway sets this automatically, leave as 5001 locally)
PORT=5001
